# RADAR — example environment.
#
# Copy to `.env` and edit if you need different values:
#   cp .env.example .env
#
# Every key here maps 1:1 to a field on rag_lib.api.settings.Settings;
# unknown keys are ignored. Paths use the in-container layout (/app/...);
# docker-compose bind-mounts ./data, ./vault, ./chroma onto those paths.

RADAR_DB_PATH=/app/data/radar.db
RADAR_DEFAULT_MAILTO=demo@example.com
RADAR_VAULT_DIR=/app/vault
RADAR_CHROMA_DIR=/app/chroma
RADAR_OLLAMA_URL=http://ollama:11434
RADAR_OLLAMA_MODEL=qwen2.5:7b-instruct
# Embedder used by chat retrieval (parallel to SPECTER2 used by selectors).
# Indexed into a per-user `vault_chat` collection at upload time.
# Best-effort: if ollama is down or the model isn't pulled, upload still
# succeeds and chat falls back to SPECTER2. Set empty to disable.
RADAR_CHAT_EMBEDDING_MODEL=mxbai-embed-large
RADAR_CORS_ORIGINS=["http://localhost:5173"]
RADAR_SCHEDULER_ENABLED=true
RADAR_REQUIRE_AUTH=true
RADAR_LOG_JSON=true

# --- Host-side bind-mount paths -------------------------------------------
# Where state lives on the *host*. The in-container paths above (/app/data
# etc.) are fixed; these vars only change where compose mounts them from.
# Defaults (used when these are unset) are ./data, ./vault, ./chroma,
# ./ollama relative to docker-compose.yml. Uncomment + set to absolute
# paths to put state elsewhere (e.g. on a larger disk).
#
#RADAR_HOST_DATA_DIR=/var/lib/radar/data
#RADAR_HOST_VAULT_DIR=/var/lib/radar/vault
#RADAR_HOST_CHROMA_DIR=/var/lib/radar/chroma
#RADAR_HOST_OLLAMA_DIR=/var/lib/radar/ollama
